# Flask
SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///decisions.db

# Claude via 七牛云中转（或直连 Anthropic 时留空 ANTHROPIC_BASE_URL）
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_BASE_URL=https://api.qnaigc.com

# GPT-4.5 via relay
OPENAI_BASE_URL=https://your-relay-url/v1
OPENAI_API_KEY=your-relay-key-here

# 豆包 Lite (字节跳动火山引擎) - 对话引导
DOUBAO_API_KEY=your-doubao-key-here
DOUBAO_MODEL=doubao-lite-32k  # 或填你创建的 endpoint ID

# 讯飞 STT (语音转文字，可选)
XFYUN_APP_ID=your-xfyun-appid
XFYUN_API_KEY=your-xfyun-key
XFYUN_API_SECRET=your-xfyun-secret

# TTS 使用 Edge TTS，免费无需配置
